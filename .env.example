NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://milox:change-me@localhost:5432/milox?schema=public
WEB_ORIGIN=http://localhost:3000
PUBLIC_WEB_ORIGIN=https://milox.in
ADMIN_ORIGIN=http://localhost:3002
CORS_ORIGINS=https://milox.in,https://www.milox.in
# Public URL browsers use for media links — must match your live API domain.
API_PUBLIC_URL=http://localhost:3001
# Production example:
# API_PUBLIC_URL=https://api.milox.in
UPLOAD_ROOT=../../uploads

# Generate strong, distinct secrets for every environment.
JWT_ACCESS_SECRET=replace-with-at-least-32-random-bytes
CURSOR_SIGNING_SECRET=replace-with-a-different-32-byte-secret
JWT_ACCESS_TTL_SECONDS=900
JWT_ISSUER=milox-api
JWT_AUDIENCE=milox-clients
REFRESH_TOKEN_TTL_DAYS=30
EMAIL_VERIFICATION_TTL_HOURS=24
PASSWORD_RESET_TTL_MINUTES=30

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=no-reply@example.com
EMAIL_WORKER_POLL_MS=5000
FEED_SCORE_POLL_MS=300000
INTEREST_DAILY_LIMIT=20
WALLET_WELCOME_BONUS=500
REFERRAL_REWARD_POINTS=100
POST_REWARD_POINTS=5
INTEREST_SEND_COST=10
CHAT_OUTBOX_POLL_MS=500
NOTIFICATION_OUTBOX_POLL_MS=500

# Firebase Cloud Messaging (push notifications)
# Local dev: path to the service account JSON downloaded from Firebase Console.
GOOGLE_APPLICATION_CREDENTIALS=./secrets/milox-app-firebase-adminsdk-fbsvc-06c2578017.json

# Development only — accept dev-admin-bypass token (default on in dev unless false)
# ADMIN_AUTH_BYPASS=true
